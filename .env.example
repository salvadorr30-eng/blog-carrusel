# MailerLite (newsletter)
# 1) Saca tu token en: https://dashboard.mailerlite.com → Integrations → MailerLite API
# 2) Crea un grupo en Subscribers → Groups y copia su ID (lo ves en la URL).
MAILERLITE_API_KEY=
MAILERLITE_GROUP_ID=

# Shopify (solo si luego conectas la Storefront API)
SHOPIFY_STORE_DOMAIN=
SHOPIFY_STOREFRONT_ACCESS_TOKEN=
